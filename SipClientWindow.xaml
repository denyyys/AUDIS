<Window x:Class="AudisService.SipClientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Audis — SIP Client"
        Height="720" Width="440"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#F2F2F2"
        Closing="Window_Closing">

    <Window.Resources>

        <!-- Modern flat button (matching main window) -->
        <Style x:Key="FlatBtn" TargetType="Button">
            <Setter Property="Background"      Value="#E0E0E0"/>
            <Setter Property="Foreground"      Value="#1A1A1A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="#BDBDBD"/>
            <Setter Property="Padding"         Value="10,4"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                >
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background"  Value="#D0E8FF"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#0078D7"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background"  Value="#B8D8FF"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#005499"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#A0A0A0"/>
                                <Setter TargetName="bd" Property="Background"  Value="#F0F0F0"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#D8D8D8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dialpad button -->
        <Style x:Key="DialpadBtn" TargetType="Button">
            <Setter Property="Width"       Value="72"/>
            <Setter Property="Height"      Value="50"/>
            <Setter Property="FontSize"    Value="18"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="Background"  Value="#E8E8E8"/>
            <Setter Property="Foreground"  Value="#1A1A1A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#BDBDBD"/>
            <Setter Property="Margin"      Value="3"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                >
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#B8D8FF"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#005499"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#D0E8FF"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#0078D7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Call button (green) -->
        <Style x:Key="CallBtn" TargetType="Button">
            <Setter Property="Background" Value="#1A6E1A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="Width"      Value="120"/>
            <Setter Property="Height"     Value="38"/>
            <Setter Property="Margin"     Value="3"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="#0D3D0D"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                >
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="8,3"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background"  Value="#145214"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background"  Value="#228B22"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#AAAAAA"/>
                                <Setter TargetName="bd" Property="Background" Value="#6B9A6B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Hangup button (red) -->
        <Style x:Key="HangupBtn" TargetType="Button">
            <Setter Property="Background" Value="#A01010"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="Width"      Value="120"/>
            <Setter Property="Height"     Value="38"/>
            <Setter Property="Margin"     Value="3"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="#5A0A0A"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                >
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="8,3"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background"  Value="#7A0A0A"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background"  Value="#C01515"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#CCAAAA"/>
                                <Setter TargetName="bd" Property="Background" Value="#803030"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- title -->
            <RowDefinition Height="Auto"/>  <!-- dialler -->
            <RowDefinition Height="Auto"/>  <!-- call status -->
            <RowDefinition Height="Auto"/>  <!-- reg status -->
            <RowDefinition Height="Auto"/>  <!-- test reg + actions -->
            <RowDefinition Height="Auto"/>  <!-- audio mode selector -->
            <RowDefinition Height="Auto"/>  <!-- dialpad -->
            <RowDefinition Height="Auto"/>  <!-- log header -->
            <RowDefinition Height="*"/>     <!-- log -->
        </Grid.RowDefinitions>

        <!-- ── Title strip ─────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="#000080" Padding="10,6">
            <TextBlock Text="AUDIS SIP Client" Foreground="White"
                       FontWeight="Bold" FontSize="12" FontFamily="Tahoma"/>
        </Border>

        <!-- ── Dialler ──────────────────────────────────────────────────── -->
        <Border Grid.Row="1" Background="#F2F2F2" Padding="8,8"
                BorderBrush="#D0D0D0" BorderThickness="0,0,0,1">
            <StackPanel>
                <!-- Number input row: ComboBox + Delete button -->
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="TxtNumber"
                              IsEditable="True"
                              FontSize="15" FontFamily="Consolas"
                              Background="White"
                              Height="32"
                              KeyDown="TxtNumber_KeyDown"
                              Text=""
                              ToolTip="Type SIP URI or pick a contact — e.g. 500@192.168.1.5"/>
                    <!-- Delete button (clears text field) -->
                    <Button Grid.Column="1" Content="Del" Width="42" Height="32" Margin="4,0,0,0"
                            Style="{StaticResource FlatBtn}" FontSize="11" FontWeight="Bold"
                            Foreground="#CC2222"
                            Click="BtnDelete_Click" ToolTip="Clear number field"/>
                </Grid>

                <!-- Call / Hang Up -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="BtnCall"   Style="{StaticResource CallBtn}"   Click="BtnCall_Click">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="16" Height="16" Margin="0,0,5,0" VerticalAlignment="Center">
                                <Canvas Width="18" Height="18">
                                    <Path Fill="White"
                                          Data="M 2,2 C 2,2 4,0 6,1 L 7,3 C 7,4 7,5 6,6
                                                C 7,8 10,11 12,12
                                                C 13,11 14,11 15,12 L 16,14
                                                C 17,16 15,18 15,18
                                                C 9,20 -2,9 2,2 Z"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="Call" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnHangup" Style="{StaticResource HangupBtn}"
                            Click="BtnHangup_Click" IsEnabled="False" Margin="8,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="18" Height="12" Margin="0,0,5,0" VerticalAlignment="Center">
                                <Canvas Width="20" Height="10">
                                    <Path Fill="White" Data="M 0,6 C 0,3 2,1 4,1 L 4,4 C 3,4 2,5 2,6 Z"/>
                                    <Path Fill="White" Data="M 20,6 C 20,3 18,1 16,1 L 16,4 C 17,4 18,5 18,6 Z"/>
                                    <Path Fill="White" Data="M 4,4 C 4,2 6,0 10,0 C 14,0 16,2 16,4 L 13,4 C 13,3 12,2 10,2 C 8,2 7,3 7,4 Z"/>
                                    <Line X1="3" Y1="1" X2="17" Y2="9" Stroke="#FF3333" StrokeThickness="1.5"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="Hang Up" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ── Call status bar ─────────────────────────────────────────── -->
        <Border Grid.Row="2" Background="#1A237E" Padding="8,4">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Call: " Foreground="#90CAF9" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtStatus" Text="IDLE" Foreground="#69F0AE"
                           FontFamily="Consolas" FontWeight="Bold" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtCallTimer" Text="" Foreground="#FFD54F"
                           FontFamily="Consolas" FontSize="11" Margin="14,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ── Registration status bar ─────────────────────────────────── -->
        <Border Grid.Row="3" Background="#FAFAFA" Padding="8,5"
                BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <Ellipse x:Name="RegDot" Width="9" Height="9" Fill="#9E9E9E"
                         VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock Text="Registration: " Foreground="#606060" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtRegStatus" Text="Disabled" FontWeight="Bold" FontSize="11"
                           Foreground="#757575" VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtRegCode" Text="" FontSize="10" Foreground="#9E9E9E"
                           Margin="6,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ── Test Registration strip ──────────────────────────────────── -->
        <Border Grid.Row="4" Background="#EEEEEE" Padding="8,5"
                BorderBrush="#D0D0D0" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="BtnTestReg" Content="Test Registration"
                        Style="{StaticResource FlatBtn}"
                        Click="BtnTestReg_Click" IsEnabled="False"
                        ToolTip="Send a REGISTER to test the SIP account credentials"/>
            </StackPanel>
        </Border>

        <!-- ── Audio Mode selector ─────────────────────────────────────── -->
        <Border Grid.Row="5" Background="#F8F8F8" Padding="8,6"
                BorderBrush="#D0D0D0" BorderThickness="0,0,0,1">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Text="Greeting audio" FontWeight="Bold" FontSize="10"
                               Foreground="#555" VerticalAlignment="Center"/>
                    <CheckBox x:Name="ChkRecordCalls"
                              Content="Record calls"
                              FontSize="10" FontWeight="Bold"
                              Foreground="#1A6E1A"
                              VerticalAlignment="Center"
                              Margin="16,0,0,0"
                              Checked="ChkRecordCalls_Changed"
                              Unchecked="ChkRecordCalls_Changed"
                              ToolTip="Save each call as a WAV file in the recordings folder"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <RadioButton x:Name="RadioStandard"
                                 Content="Standard (AUDIS)"
                                 GroupName="AudioMode"
                                 FontSize="11" VerticalAlignment="Center"
                                 Margin="0,0,12,0"
                                 Checked="AudioMode_Changed"/>
                    <RadioButton x:Name="RadioCustomWav"
                                 Content="Custom .wav:"
                                 GroupName="AudioMode"
                                 FontSize="11" VerticalAlignment="Center"
                                 Margin="0,0,6,0"
                                 Checked="AudioMode_Changed"/>
                    <ComboBox x:Name="CboCustomWav"
                              Width="168" Height="22"
                              IsEnabled="False"
                              FontSize="11"
                              ToolTip="Pick a .wav file from the audio folder"
                              SelectionChanged="CboCustomWav_SelectionChanged"/>
                    <!-- Refresh icon button — circular arrow SVG path -->
                    <Button Width="26" Height="26" Margin="5,0,0,0"
                            Background="#DDE8F5" BorderBrush="#7AAFD4" BorderThickness="1"
                            Cursor="Hand"
                            Click="BtnRefreshWavs_Click"
                            ToolTip="Reload .wav files from audio folder">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background"  Value="#B8D8FF"/>
                                        <Setter TargetName="bd" Property="BorderBrush" Value="#0078D7"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="bd" Property="Background"  Value="#90C0F0"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Viewbox Width="14" Height="14">
                            <Canvas Width="24" Height="24">
                                <!-- Circular arrow (clockwise refresh) -->
                                <Path Stroke="#1A5FA8" StrokeThickness="2.4"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Fill="Transparent"
                                      Data="M 20,12 A 8,8 0 1 1 14,4.3"/>
                                <!-- Arrowhead -->
                                <Polygon Points="14,1 14,7.5 19,4.3" Fill="#1A5FA8"/>
                            </Canvas>
                        </Viewbox>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ── Dialpad ─────────────────────────────────────────────────── -->
        <Border Grid.Row="6" Background="#F2F2F2" Padding="0,6">
            <Grid HorizontalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Row="0" Grid.Column="0" Style="{StaticResource DialpadBtn}" Click="DialpadBtn_Click" Tag="1"><StackPanel><TextBlock Text="1" HorizontalAlignment="Center"/><TextBlock Text="   " FontSize="8" Foreground="#808080" HorizontalAlignment="Center"/></StackPanel></Button>
                <Button Grid.Row="0" Grid.Column="1" Style="{StaticResource DialpadBtn}" Click="DialpadBtn_Click" Tag="2"><StackPanel><TextBlock Text="2" HorizontalAlignment="Center"/><TextBlock Text="ABC" FontSize="8" Foreground="#808080" HorizontalAlignment="Center"/></StackPanel></Button>
                <Button Grid.Row="0" Grid.Column="2" Style="{StaticResource DialpadBtn}" Click="DialpadBtn_Click" Tag="3"><StackPanel><TextBlock Text="3" HorizontalAlignment="Center"/><TextBlock Text="DEF" FontSize="8" Foreground="#808080" HorizontalAlignment="Center"/></StackPanel></Button>

                <Button Grid.Row="1" Grid.Column="0" Style="{StaticResource DialpadBtn}" Click="DialpadBtn_Click" Tag="4"><StackPanel><TextBlock Text="4" HorizontalAlignment="Center"/><TextBlock Text="GHI" FontSize="8" Foreground="#808080" HorizontalAlignment="Center"/></StackPanel></Button>
                <Button Grid.Row="1" Grid.Column="1" Style="{StaticResource DialpadBtn}" Click="DialpadBtn_Click" Tag="5"><StackPanel><TextBlock Text="5" HorizontalAlignment="Center"/><TextBlock Text="JKL" FontSize="8" Foreground="#808080" HorizontalAlignment="Center"/></StackPanel></Button>
                <Button Grid.Row="1" Grid.Column="2" Style="{StaticResource DialpadBtn}" Click="DialpadBtn_Click" Tag="6"><StackPanel><TextBlock Text="6" HorizontalAlignment="Center"/><TextBlock Text="MNO" FontSize="8" Foreground="#808080" HorizontalAlignment="Center"/></StackPanel></Button>

                <Button Grid.Row="2" Grid.Column="0" Style="{StaticResource DialpadBtn}" Click="DialpadBtn_Click" Tag="7"><StackPanel><TextBlock Text="7" HorizontalAlignment="Center"/><TextBlock Text="PQRS" FontSize="8" Foreground="#808080" HorizontalAlignment="Center"/></StackPanel></Button>
                <Button Grid.Row="2" Grid.Column="1" Style="{StaticResource DialpadBtn}" Click="DialpadBtn_Click" Tag="8"><StackPanel><TextBlock Text="8" HorizontalAlignment="Center"/><TextBlock Text="TUV" FontSize="8" Foreground="#808080" HorizontalAlignment="Center"/></StackPanel></Button>
                <Button Grid.Row="2" Grid.Column="2" Style="{StaticResource DialpadBtn}" Click="DialpadBtn_Click" Tag="9"><StackPanel><TextBlock Text="9" HorizontalAlignment="Center"/><TextBlock Text="WXYZ" FontSize="8" Foreground="#808080" HorizontalAlignment="Center"/></StackPanel></Button>

                <Button Grid.Row="3" Grid.Column="0" Style="{StaticResource DialpadBtn}" Click="DialpadBtn_Click" Tag="*" FontSize="22">*</Button>
                <Button Grid.Row="3" Grid.Column="1" Style="{StaticResource DialpadBtn}" Click="DialpadBtn_Click" Tag="0"><StackPanel><TextBlock Text="0" HorizontalAlignment="Center"/><TextBlock Text="+" FontSize="8" Foreground="#808080" HorizontalAlignment="Center"/></StackPanel></Button>
                <Button Grid.Row="3" Grid.Column="2" Style="{StaticResource DialpadBtn}" Click="DialpadBtn_Click" Tag="#" FontSize="18">#</Button>
            </Grid>
        </Border>

        <!-- ── Log header ─────────────────────────────────────────────── -->
        <Border Grid.Row="7" Background="#E8E8E8" Padding="8,5"
                BorderBrush="#C8C8C8" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Client Log" FontWeight="Bold" FontSize="11" VerticalAlignment="Center"/>
                <Button Content="Clear"  Click="BtnClearLog_Click"  Style="{StaticResource FlatBtn}"
                        Padding="8,2" Margin="8,0,0,0" FontSize="10"/>
                <Button Content="Export" Click="BtnExportLog_Click" Style="{StaticResource FlatBtn}"
                        Padding="8,2" Margin="4,0,0,0" FontSize="10"/>
            </StackPanel>
        </Border>

        <!-- ── Log area ───────────────────────────────────────────────── -->
        <ListBox Grid.Row="8" x:Name="LogList"
                 FontFamily="Consolas" FontSize="10" Background="White"
                 BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Auto">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding}" TextWrapping="NoWrap"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
