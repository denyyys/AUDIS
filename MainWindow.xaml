<Window x:Class="AudisService.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Audis - Kybl Enterprise" Height="640" Width="860"
        ResizeMode="CanResizeWithGrip"
        Loaded="Window_Loaded"
        Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">

    <Window.Resources>
        <Style x:Key="TbBtn" TargetType="Button">
            <Setter Property="Background"      Value="#E8E8E8"/>
            <Setter Property="Foreground"      Value="#1A1A1A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="Transparent"/>
            <Setter Property="Padding"         Value="8,4"/>
            <Setter Property="Margin"          Value="2,2"/>
            <Setter Property="MinWidth"        Value="68"/>
            <Setter Property="Height"          Value="56"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#0078D7"/>
                                <Setter TargetName="bd" Property="Background"  Value="#D0E4F8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#005499"/>
                                <Setter TargetName="bd" Property="Background"  Value="#B0CCEE"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background"  Value="#F0F0F0"/>
                                <Setter Property="Foreground" Value="#A8A8A8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Status bar ──────────────────────────────────────────────────── -->
        <Border Grid.Row="0" BorderThickness="0,0,0,1" BorderBrush="#DDDDDD" Padding="0,0,0,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Service Status:" VerticalAlignment="Center" Margin="0,0,5,0" Foreground="Gray"/>
                <TextBlock x:Name="StatusTxt" Text="STOPPED" FontWeight="Bold" Foreground="Red"
                           VerticalAlignment="Center" Width="80"/>
                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="10,0"/>
                <Button x:Name="BtnStart" Content=" Start Service " Click="BtnStart_Click" Padding="10,3" Margin="2,0"/>
                <Button x:Name="BtnStop"  Content=" Stop Service "  Click="BtnStop_Click"  Padding="10,3" Margin="2,0" IsEnabled="False"/>
                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="10,0"/>
                <TextBlock Text="AI:" VerticalAlignment="Center" Margin="0,0,5,0" Foreground="Gray"/>
                <TextBlock x:Name="AiStatusTxt" Text="OFFLINE" FontWeight="Bold" Foreground="Red"
                           VerticalAlignment="Center" Width="70"/>
                <Button x:Name="BtnStartAi" Content=" Start AI " Click="BtnStartAi_Click" Padding="8,3" Margin="2,0"/>
                <Button x:Name="BtnStopAi"  Content=" Stop AI "  Click="BtnStopAi_Click"  Padding="8,3" Margin="2,0" IsEnabled="False"/>
                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="10,0"/>
                <CheckBox x:Name="ChkRec" Content=" Call Recording"
                          IsChecked="{Binding IsRecordingEnabled, Mode=TwoWay}"
                          VerticalAlignment="Center" Margin="5,0,0,0"/>
                <TextBlock Text="(Restart Required)" FontSize="10" Foreground="Gray"
                           VerticalAlignment="Center" Margin="3,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- ── Toolbar ──────────────────────────────────────────────────────── -->
        <Border Grid.Row="1" Background="#E0E0E0"
                BorderBrush="#B0B0B0" BorderThickness="0,1,0,1"
                Padding="6,4" Margin="0,0,0,6">
            <StackPanel Orientation="Horizontal">

                <!-- SIP Client -->
                <Button Style="{StaticResource TbBtn}" Click="TbSipClient_Click"
                        ToolTip="Open SIP Client  |  Right-click to change icon">
                    <Button.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Change Icon…" Tag="SipClient" Click="TbChangeIcon_Click"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                    <StackPanel Margin="4,2">
                        <Image x:Name="ImgSipClient" Width="28" Height="28" Margin="0,0,0,3"/>
                        <TextBlock Text="SIP Client" FontSize="9" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- SIP Settings -->
                <Button Style="{StaticResource TbBtn}" Click="TbSipSettings_Click"
                        ToolTip="SIP Client settings  |  Right-click to change icon">
                    <Button.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Change Icon…" Tag="SipSettings" Click="TbChangeIcon_Click"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                    <StackPanel Margin="4,2">
                        <Image x:Name="ImgSipSettings" Width="28" Height="28" Margin="0,0,0,3"/>
                        <TextBlock Text="SIP Client Config" FontSize="9" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Server Config -->
                <Button Style="{StaticResource TbBtn}" Click="TbServerConfig_Click"
                        ToolTip="Server settings  |  Right-click to change icon">
                    <Button.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Change Icon…" Tag="ServerConfig" Click="TbChangeIcon_Click"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                    <StackPanel Margin="4,2">
                        <Image x:Name="ImgServerConfig" Width="28" Height="28" Margin="0,0,0,3"/>
                        <TextBlock Text="Server Config" FontSize="9" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Rectangle Width="1" Fill="#B0B0B0" Margin="8,6" VerticalAlignment="Stretch"/>

                <!-- Call Log -->
                <Button Style="{StaticResource TbBtn}" Click="TbCallLog_Click"
                        ToolTip="View call log  |  Right-click to change icon">
                    <Button.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Change Icon…" Tag="CallLog" Click="TbChangeIcon_Click"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                    <StackPanel Margin="4,2">
                        <Image x:Name="ImgCallLog" Width="28" Height="28" Margin="0,0,0,3"/>
                        <TextBlock Text="Call Log" FontSize="9" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Help -->
                <Button Style="{StaticResource TbBtn}" Click="TbHelp_Click"
                        ToolTip="Help – Audis user manual  |  Right-click to change icon">
                    <Button.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Change Icon…" Tag="Help" Click="TbChangeIcon_Click"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                    <StackPanel Margin="4,2">
                        <Image x:Name="ImgHelp" Width="28" Height="28" Margin="0,0,0,3"/>
                        <TextBlock Text="Help" FontSize="9" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Rectangle Width="1" Fill="#B0B0B0" Margin="8,6" VerticalAlignment="Stretch"/>

                <!-- ── Web Client ──────────────────────────────────────────── -->
                <Button x:Name="BtnWebClient" Style="{StaticResource TbBtn}"
                        Click="TbWebClient_Click"
                        ToolTip="Start / stop web SIP client — opens the interface in your browser  |  Right-click to change icon">
                    <Button.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Change Icon…" Tag="WebClient"
                                      Click="TbChangeIcon_Click"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                    <StackPanel Margin="4,2">
                        <!-- icon + status dot overlay -->
                        <Grid Width="28" Height="28" Margin="0,0,0,3">
                            <Image x:Name="ImgWebClient" Width="28" Height="28"/>
                            <!-- red = stopped, green = running -->
                            <Ellipse x:Name="WebDot"
                                     Width="9" Height="9"
                                     Fill="#CC2222"
                                     Stroke="White" StrokeThickness="1"
                                     HorizontalAlignment="Right"
                                     VerticalAlignment="Bottom"/>
                        </Grid>
                        <TextBlock x:Name="TxtWebLabel"
                                   Text="Web Client"
                                   FontSize="9" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

            </StackPanel>
        </Border>

        <!-- ── Tabs ─────────────────────────────────────────────────────────── -->
        <TabControl Grid.Row="2" BorderThickness="0" Background="Transparent">

            <TabItem Header="Dashboard">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Active Calls" FontWeight="Bold" Margin="0,0,0,5"/>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding ActiveCalls}" AutoGenerateColumns="False"
                              IsReadOnly="True" HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              Background="White" BorderThickness="1" BorderBrush="#EEEEEE" Margin="0,0,0,15">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Call ID"    Binding="{Binding CallId}"      Width="*"/>
                            <DataGridTextColumn Header="Extension"  Binding="{Binding Extension}"   Width="120"/>
                            <DataGridTextColumn Header="Status"     Binding="{Binding Status}"      Width="100"/>
                            <DataGridTextColumn Header="Duration"   Binding="{Binding DurationStr}" Width="80"/>
                            <DataGridTextColumn Header="Last Input" Binding="{Binding LastInput}"   Width="80"/>
                            <DataGridTextColumn Header="Active"     Binding="{Binding IsActive}"    Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <Grid Grid.Row="2" Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Recent Recordings" FontWeight="Bold" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="Refresh"     Click="BtnRefreshRecordings_Click"    Padding="5,2" Margin="0,0,5,0"/>
                            <Button Content="Open Folder" Click="BtnOpenRecordingsFolder_Click" Padding="5,2"/>
                        </StackPanel>
                    </Grid>
                    <ListBox x:Name="RecordingsList" Grid.Row="3" BorderThickness="1" BorderBrush="#EEEEEE" Background="White">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Margin="0,0,10,0"/>
                                    <TextBlock Text="{Binding CreationTime, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Foreground="Gray"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </TabItem>

            <TabItem Header="Key Mappings">
                <DataGrid ItemsSource="{Binding Mappings}" AutoGenerateColumns="False"
                          Background="White" BorderThickness="1" BorderBrush="#EEEEEE">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Key"               Binding="{Binding Key}"   Width="50" IsReadOnly="True" FontWeight="Bold"/>
                        <DataGridTextColumn Header="Action / Filename" Binding="{Binding Value}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Audio Files">
                <Grid Margin="0,5,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ListBox x:Name="FileList" Grid.Column="0" BorderThickness="1" BorderBrush="#EEEEEE"/>
                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                        <Button Content="Refresh List" Click="BtnRefreshFiles_Click" Margin="0,0,0,5" Padding="10,3"/>
                        <Button Content="Open Folder"  Click="BtnOpenFolder_Click"  Padding="10,3"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="System Logs">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
                        <Button Content="Export Logs" Click="BtnExportLogs_Click" Padding="10,3" Margin="0,0,5,0"/>
                        <Button Content="Clear Logs"  Click="BtnClearLogs_Click"  Padding="10,3" Margin="0,0,5,0"/>
                        <TextBlock Text="AUDIS server log" VerticalAlignment="Center"
                                   Foreground="Gray" FontSize="11" Margin="10,0,0,0"/>
                    </StackPanel>
                    <ListBox x:Name="LogList" Grid.Row="1" FontFamily="Consolas" FontSize="11"
                             BorderThickness="1" BorderBrush="#EEEEEE" Background="#FAFAFA">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding FullMessage}" TextWrapping="Wrap"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </TabItem>

            <TabItem Header="About">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Image x:Name="LogoImage" Width="128" Height="128" Margin="0,0,0,20"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="AUDIS"                            FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Enterprise SIP Manager"           FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                    <TextBlock Text="Version: 1.4"                     HorizontalAlignment="Center"/>
                    <TextBlock Text="Copyright © 2026 Kybl Enterprise" HorizontalAlignment="Center"/>
                    <TextBlock Text="All Rights Reserved."             HorizontalAlignment="Center" Margin="0,0,0,20"/>
                    <TextBlock FontSize="10" Foreground="Gray" HorizontalAlignment="Center"
                               TextWrapping="Wrap" MaxWidth="300" TextAlignment="Center"
                               Text="Warning: This computer program is protected by copyright law."/>
                </StackPanel>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
