<Window x:Class="AudisService.IconPicker"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Choose Icon"
        Height="720" Width="940"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Select a DLL, set the index range, click Load — then click any icon and press OK."
                   FontWeight="Bold" Margin="0,0,0,6"/>

        <!-- Controls bar -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="DLL:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <ComboBox x:Name="CmbDll" Width="310" SelectedIndex="0">
                <ComboBoxItem Content="shell32.dll"          Tag="C:\Windows\System32\shell32.dll"/>
                <ComboBoxItem Content="imageres.dll"         Tag="C:\Windows\System32\imageres.dll"/>
                <ComboBoxItem Content="mmcndmgr.dll"         Tag="C:\Windows\System32\mmcndmgr.dll"/>
                <ComboBoxItem Content="ieframe.dll"          Tag="C:\Windows\System32\ieframe.dll"/>
                <ComboBoxItem Content="wmploc.dll"           Tag="C:\Windows\System32\wmploc.dll"/>
                <ComboBoxItem Content="moricons.dll"         Tag="C:\Windows\System32\moricons.dll"/>
                <ComboBoxItem Content="netshell.dll"         Tag="C:\Windows\System32\netshell.dll"/>
                <ComboBoxItem Content="pifmgr.dll"           Tag="C:\Windows\System32\pifmgr.dll"/>
                <ComboBoxItem Content="accessibilitycpl.dll" Tag="C:\Windows\System32\accessibilitycpl.dll"/>
                <ComboBoxItem Content="ddores.dll"           Tag="C:\Windows\System32\ddores.dll"/>
                <ComboBoxItem Content="dmdskres.dll"         Tag="C:\Windows\System32\dmdskres.dll"/>
                <ComboBoxItem Content="networkexplorer.dll"  Tag="C:\Windows\System32\networkexplorer.dll"/>
                <ComboBoxItem Content="setupapi.dll"         Tag="C:\Windows\System32\setupapi.dll"/>
                <ComboBoxItem Content="compstui.dll"         Tag="C:\Windows\System32\compstui.dll"/>
                <ComboBoxItem Content="dsuiext.dll"          Tag="C:\Windows\System32\dsuiext.dll"/>
            </ComboBox>
            <TextBlock Text="  Range:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox x:Name="TxtFrom" Text="0"   Width="50" Margin="0,0,4,0"/>
            <TextBlock Text="–" VerticalAlignment="Center" Margin="0,0,4,0"/>
            <TextBox x:Name="TxtTo"   Text="300" Width="50" Margin="0,0,8,0"/>
            <Button Content="Load Icons" Click="BtnLoad_Click" Padding="12,4"/>
            <TextBlock x:Name="TxtFoundCount" VerticalAlignment="Center"
                       Margin="12,0,0,0" Foreground="Gray" FontSize="11"/>
        </StackPanel>

        <!-- Icon grid -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <WrapPanel x:Name="IconPanel"/>
        </ScrollViewer>

        <!-- Selection preview -->
        <Border Grid.Row="3" Background="#F0F0F0" BorderBrush="#CCCCCC"
                BorderThickness="0,1,0,0" Padding="8,6" Margin="0,8,0,4">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Selected:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <Image x:Name="SelImg" Width="32" Height="32" Margin="0,0,8,0"/>
                <TextBlock x:Name="SelTxt" Text="(none)" VerticalAlignment="Center"
                           FontFamily="Consolas" FontSize="13" FontWeight="Bold" Foreground="#333"/>
            </StackPanel>
        </Border>

        <!-- Dialog buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnReset"  Content="Reset to Default" Click="BtnReset_Click"
                    Padding="12,4" Margin="0,0,8,0"/>
            <Button x:Name="BtnOk"     Content="OK"     Click="BtnOk_Click"
                    Padding="28,4" Margin="0,0,6,0" IsDefault="True" IsEnabled="False"/>
            <Button x:Name="BtnCancel" Content="Cancel" Click="BtnCancel_Click"
                    Padding="16,4" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
