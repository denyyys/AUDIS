<Window x:Class="AudisService.SipClientSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SIP Client Config"
        Height="540" Width="460"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#F2F2F2">

    <Window.Resources>

        <!-- Modern flat button -->
        <Style TargetType="Button">
            <Setter Property="Background"      Value="#E0E0E0"/>
            <Setter Property="Foreground"      Value="#1A1A1A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="#BDBDBD"/>
            <Setter Property="Padding"         Value="14,5"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                               >
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background"  Value="#D0E8FF"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#0078D7"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background"  Value="#B8D8FF"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#005499"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#A0A0A0"/>
                                <Setter TargetName="bd" Property="Background"  Value="#F0F0F0"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#D8D8D8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background"      Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="#BDBDBD"/>
            <Setter Property="Padding"         Value="4,3"/>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Background"      Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="#BDBDBD"/>
            <Setter Property="Padding"         Value="4,3"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background"      Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="#BDBDBD"/>
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="Margin"          Value="0,0,0,8"/>
            <Setter Property="Padding"         Value="8,6,8,8"/>
            <Setter Property="BorderBrush"     Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background"      Value="White"/>
        </Style>

        <!-- Tab items — neutral light grey, not brown -->
        <Style TargetType="TabItem">
            <Setter Property="Background"  Value="#E4E4E4"/>
            <Setter Property="Foreground"  Value="#1A1A1A"/>
            <Setter Property="Padding"     Value="12,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="#C0C0C0" BorderThickness="1,1,1,0"
                               
                                Margin="1,2,1,0">
                            <ContentPresenter ContentSource="Header"
                                              Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background"  Value="White"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#A0A0A0"/>
                                <Setter Property="Foreground" Value="#000080"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#D8EEFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Background="White" BorderBrush="#C0C0C0">

            <!-- ── NETWORK ──────────────────────────────────────────────── -->
            <TabItem Header="Network">
                <StackPanel Margin="8" Background="White">
                    <GroupBox Header="Local SIP">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Local SIP Port:" VerticalAlignment="Center" Margin="0,5"/>
                            <TextBox   Grid.Row="0" Grid.Column="1" x:Name="TxtSipPort" Margin="0,5"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="RTP Port Start:" VerticalAlignment="Center" Margin="0,5"/>
                            <TextBox   Grid.Row="1" Grid.Column="1" x:Name="TxtRtpStart" Margin="0,5"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="RTP Port End:"   VerticalAlignment="Center" Margin="0,5"/>
                            <TextBox   Grid.Row="2" Grid.Column="1" x:Name="TxtRtpEnd"   Margin="0,5"/>
                        </Grid>
                    </GroupBox>
                    <GroupBox Header="NAT / Contact">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Public IP:" VerticalAlignment="Center" Margin="0,5"/>
                            <TextBox   Grid.Column="1" x:Name="TxtPublicIp" Margin="0,5"/>
                        </Grid>
                    </GroupBox>
                </StackPanel>
            </TabItem>

            <!-- ── SIP ACCOUNT ──────────────────────────────────────────── -->
            <TabItem Header="SIP Account">
                <StackPanel Margin="8" Background="White">
                    <CheckBox x:Name="ChkUseReg" Content="Enable SIP Registration" Margin="0,6,0,10"
                              Checked="ChkUseReg_Changed" Unchecked="ChkUseReg_Changed"/>

                    <GroupBox Header="Account" x:Name="GrpAccount">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="SIP Server:"     VerticalAlignment="Center" Margin="0,4"/>
                            <TextBox   Grid.Row="0" Grid.Column="1" x:Name="TxtSipServer"  Margin="0,4"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="SIP Proxy:"      VerticalAlignment="Center" Margin="0,4"/>
                            <TextBox   Grid.Row="1" Grid.Column="1" x:Name="TxtSipProxy"   Margin="0,4"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Username:"        VerticalAlignment="Center" Margin="0,4"/>
                            <TextBox   Grid.Row="2" Grid.Column="1" x:Name="TxtUsername"   Margin="0,4"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Domain:"          VerticalAlignment="Center" Margin="0,4"/>
                            <TextBox   Grid.Row="3" Grid.Column="1" x:Name="TxtDomain"     Margin="0,4"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Password:"        VerticalAlignment="Center" Margin="0,4"/>
                            <PasswordBox Grid.Row="4" Grid.Column="1" x:Name="PbPassword"  Margin="0,4"/>
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Display Name:"   VerticalAlignment="Center" Margin="0,4"/>
                            <TextBox   Grid.Row="5" Grid.Column="1" x:Name="TxtDisplayName" Margin="0,4"/>
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Transport:"      VerticalAlignment="Center" Margin="0,4"/>
                            <ComboBox  Grid.Row="6" Grid.Column="1" x:Name="CmbTransport"  Margin="0,4">
                                <ComboBoxItem Content="UDP"/>
                                <ComboBoxItem Content="TCP"/>
                                <ComboBoxItem Content="TLS"/>
                            </ComboBox>
                        </Grid>
                    </GroupBox>
                </StackPanel>
            </TabItem>

            <!-- ── MEDIA ────────────────────────────────────────────────── -->
            <TabItem Header="Media">
                <StackPanel Margin="8" Background="White">
                    <GroupBox Header="DTMF Method">
                        <StackPanel>
                            <RadioButton x:Name="RbRfc2833" Content="RFC 2833 / RFC 4733 (in-band RTP event)" Margin="0,5"/>
                            <RadioButton x:Name="RbSipInfo" Content="SIP INFO (out-of-band)"                   Margin="0,5"/>
                            <TextBlock FontSize="10" Foreground="#606060" TextWrapping="Wrap" Margin="0,6,0,0"
                                       Text="RFC 2833 works with most SIP phones and providers. Use SIP INFO only if your server requires it."/>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="Codec Preference">
                        <StackPanel>
                            <RadioButton x:Name="RbPcmu" Content="PCMU (G.711 μ-law) – recommended" Margin="0,5"/>
                            <RadioButton x:Name="RbPcma" Content="PCMA (G.711 A-law)"                Margin="0,5"/>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </TabItem>

            <!-- ── CONTACTS ─────────────────────────────────────────────── -->
            <TabItem Header="Contacts">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Contact list -->
                    <Border Grid.Row="0" BorderBrush="#D0D0D0" BorderThickness="1">
                        <DataGrid x:Name="ContactsGrid"
                                  AutoGenerateColumns="False"
                                  Background="White"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  CanUserAddRows="True"
                                  CanUserDeleteRows="True"
                                  SelectionMode="Single"
                                  BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name"      Binding="{Binding Name}"      Width="*"/>
                                <DataGridTextColumn Header="Extension" Binding="{Binding Extension}" Width="140"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <!-- Quick-add + Remove row -->
                    <Border Grid.Row="1" Background="#F0F0F0" Padding="6,6"
                            Margin="0,6,0,0" BorderBrush="#D0D0D0" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtNewName" Margin="0,0,6,0" ToolTip="Contact name"/>
                            <TextBox x:Name="TxtNewExt"  Grid.Column="1" Margin="0,0,6,0" ToolTip="Extension / number"/>
                            <Button  Grid.Column="2" Content="Add"    Padding="10,4" Margin="0,0,4,0"
                                     Click="BtnAddContact_Click"/>
                            <Button  Grid.Column="3" Content="Remove" Padding="10,4"
                                     Click="BtnRemoveContact_Click"/>
                        </Grid>
                    </Border>

                    <TextBlock Grid.Row="2" Text="Contacts appear as selectable options in the SIP Client dialler."
                               FontSize="10" Foreground="Gray" Margin="0,6,0,0" TextWrapping="Wrap"/>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- ── Bottom buttons ───────────────────────────────────────────── -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Save"   Click="BtnSave_Click"   Margin="0,0,6,0"/>
            <Button Content="Cancel" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
